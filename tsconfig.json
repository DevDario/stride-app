{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@screens/*": ["src/features/*"],
      "@hooks/*": ["src/hooks/*"],
      "@widgets/*": ["src/widgets/*"],
      "@store/*": ["src/store/*"],
      "@utils/*": ["src/utils/*"],
      "@api/*": ["src/services/api/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
