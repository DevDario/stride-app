{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "API_URL": "${API_URL}",
        "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}",
        "STORAGE_KEY": "${STORAGE_KEY}"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_URL": "${API_URL}",
        "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}",
        "STORAGE_KEY": "${STORAGE_KEY}"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_URL": "${API_URL}",
        "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}",
        "STORAGE_KEY": "${STORAGE_KEY}"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
